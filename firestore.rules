rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザープロフィール
    match /users/{uid} {
      // 本人のみ読み書き可能（管理者フラグはFirebaseコンソールで手動設定）
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;

      // ブックマーク（本人のみ）
      match /bookmarks/{bookmarkId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // 保存済みトピック（本人のみ）
      match /savedTopics/{topicId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // 閲覧履歴（本人のみ）
      match /viewedTopics/{topicId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 参考書ルーム
    match /rooms/{roomId} {
      // 誰でも読める（匿名含む）
      allow read: if true;
      // 認証済み（匿名含む）なら作成可能
      allow create: if request.auth != null;
      // 管理者のみ削除可能
      allow delete: if isAdmin();
      // 更新は管理者のみ
      allow update: if isAdmin();

      // ミニルーム
      match /miniRooms/{miniRoomId} {
        allow read: if true;
        allow create: if request.auth != null;
        // 作成者 or 管理者が削除可能
        allow delete: if request.auth != null
          && (resource.data.createdBy == request.auth.uid || isAdmin());
        // messageCount の increment など許可
        allow update: if request.auth != null;

        // メッセージ
        match /messages/{messageId} {
          allow read: if true;
          // 認証済み（匿名含む）なら投稿可能。自分のメッセージのみ
          allow create: if request.auth != null
            && request.resource.data.userId == request.auth.uid;
          // 自分のメッセージ削除 or 管理者削除
          allow delete: if request.auth != null
            && (resource.data.userId == request.auth.uid || isAdmin());
          // リアクション更新のみ許可（reactionsフィールドの変更）
          allow update: if request.auth != null;
        }
      }
    }

    // 管理者判定：users/{uid}.isAdmin == true
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
